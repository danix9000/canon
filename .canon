# Run with debug logs
LOG=log.txt go run .

# Run all tests
go test -v ./...

# Run integration tests only
go test -v -run "Test(DirectCommand|ZshWidget|Matching|QueryScrolling|CommandHorizontalScrolling|CommandWordScrolling|AltBackspace|DescriptionVerticalScrolling|SourceDisplay)" ./...

# Run unit tests only
go test -v -run "Test(FuzzyMatch|WrapText|Hyphenate|DeletePrevWord)" ./...

# Build the binary
go build -o canon .

# Vet for common mistakes
go vet ./...

# Run the build-lint-test GitHub workflow locally
act -j build-lint-test

# Run the build-lint-test GitHub workflow locally. Leave the Docker container running.
act -j build-lint-test --reuse

# Tag and push a new release
git tag v0.1.0 && git push --tags

# Tail debug log
tail -f log.txt

# Reload the current zsh session
omz reload

# Reset the terminal
reset
